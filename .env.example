
# DATABASE_URL: PostgreSQL connection string (required)
# Get from: Supabase → Project Settings → Database → Connection String (URI mode)
# Use port 5432 (Session mode), NOT 6543 (Transaction mode)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT_SECRET: Cryptographic session secret key for JWT signing (minimum 32 characters)
JWT_SECRET=""

# SUPABASE_URL: The URL of your Supabase Project (optional, for client-side SDK)
SUPABASE_URL="https://[project-ref].supabase.co"

# SUPABASE_ANON_KEY: The public anonymous API key for Supabase (optional, for client-side SDK)
SUPABASE_ANON_KEY=""

# SUPABASE_SERVICE_ROLE_KEY: Service role key for server-side Supabase Storage uploads (required for media upload on Vercel)
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=""
